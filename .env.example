# ═══════════════════════════════════════════════════════════
#  PLANTAIN AI — FREE TIER .env (Copy this to your .env file)
#  ALL services below are FREE for prototype development
# ═══════════════════════════════════════════════════════════

# ── FLASK ─────────────────────────────────────────────────
# Generate one free at: python -c "import secrets; print(secrets.token_hex())"
SECRET_KEY=change_this_to_a_random_string_now

# ── DATABASE (local MySQL — FREE) ─────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=plantain_db

# ── GROQ AI (FREE — 14,400 requests/day, no card needed) ──
# Get key FREE at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_key_here

# ── AFRICA'S TALKING (FREE SANDBOX) ───────────────────────
# Register FREE at: https://account.africastalking.com/auth/register
# Use sandbox — no real SMS sent, zero cost
AT_USERNAME=sandbox
AT_API_KEY=atsk_3779171b85277fea25413308149bcb4da2e691b097f2d319ceaccc61130ec1624cfcbdee
AT_SENDER_ID=PlantainAI
# ⚠️  COST STARTS when you change AT_USERNAME to your live username
# Live SMS cost: ~KSh 1 per message

# ── SAFARICOM DARAJA M-PESA (FREE SANDBOX) ────────────────
# Register FREE at: https://developer.safaricom.co.ke
# Sandbox = no real money, use test number: 254708374149
MPESA_SANDBOX=true
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
# For local testing, use ngrok: ngrok http 5000
# Then set: MPESA_CALLBACK_URL=https://abc123.ngrok.io/mpesa/callback
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback
# ⚠️  COST STARTS when MPESA_SANDBOX=false + real shortcode

# ── OPEN-METEO WEATHER (100% FREE — no key needed) ────────
# No configuration needed. Works automatically.

# ── COPERNICUS SATELLITE NDVI (FREE) ──────────────────────
# Register FREE at: https://dataspace.copernicus.eu
# For prototype, NDVI is estimated from weather data (no key needed)
# Add real key later for actual satellite imagery
# COPERNICUS_CLIENT_ID=your_id
# COPERNICUS_CLIENT_SECRET=your_secret

# ═══════════════════════════════════════════════════════════
#  COST SUMMARY FOR PROTOTYPE
#  ✅ Groq AI:           FREE (14,400 req/day)
#  ✅ Weather:           FREE (unlimited)
#  ✅ AT SMS sandbox:    FREE (fake SMS, no real sending)
#  ✅ M-Pesa sandbox:    FREE (fake payments, test only)
#  ✅ MySQL local:       FREE
#  ✅ Maps/Charts:       FREE (open source)
#  ✅ NDVI satellite:    FREE (weather proxy for now)
#  ─────────────────────────────────────────────────────────
#  TOTAL MONTHLY COST FOR PROTOTYPE: KSh 0
# ═══════════════════════════════════════════════════════════
